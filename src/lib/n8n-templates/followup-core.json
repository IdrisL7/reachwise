          "conditions": [
            {
              "id": "has-leads",
              "leftValue": "={{$json.leads.length}}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "has-due-leads",
