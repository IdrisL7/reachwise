      ]
    },
    "Lead Exists?": {
      "main": [
        [
          {
            "node": "Update Salesforce Lead",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Create Salesforce Lead",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch New SF Leads": {
      "main": [
        [
          {
            "node": "Has New SF Leads?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has New SF Leads?": {
      "main": [
        [
          {
            "node": "Split Out Records",
            "type": "main",
            "index": 0
          }
        ],
