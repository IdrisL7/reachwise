# ============================================================
# GetSignalHooks — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Required variables must be set for the app to run.
# ============================================================

# ── Auth ──────────────────────────────────────────────────────
AUTH_SECRET=          # openssl rand -base64 32
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Turso) ─────────────────────────────────────────
TURSO_DATABASE_URL=   # libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# ── AI & Research ────────────────────────────────────────────
CLAUDE_API_KEY=       # Anthropic API key
BRAVE_API_KEY=        # Brave Search API key

# ── Email (SendGrid) ────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=  # Verified sender email

# ── Payments (Stripe) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=  # Stripe Price ID for Starter tier
STRIPE_PRICE_PRO=      # Stripe Price ID for Pro tier
STRIPE_PRICE_CONCIERGE= # Stripe Price ID for Concierge tier

# ── Internal Auth ───────────────────────────────────────────
FOLLOWUP_ENGINE_API_TOKEN=  # Bearer token for n8n -> API calls
CRON_SECRET=                # Vercel Cron job auth

# ============================================================
# Optional — CRM Integrations
# ============================================================

# ── HubSpot OAuth ───────────────────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── Salesforce OAuth ────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# ============================================================
# Optional — Monitoring
# ============================================================

# ── Sentry ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ============================================================
# Optional — Slack Notifications
# ============================================================

SLACK_WEBHOOK_URL=

# ============================================================
# Optional — VPS/Docker (n8n container management)
# ============================================================

N8N_DOCKER_IMAGE=n8nio/n8n:latest
N8N_PORT_START=5700
N8N_PORT_END=5799
N8N_DOCKER_NETWORK=gsh-network
N8N_DOMAIN=
APP_DOMAIN=
CADDY_ADMIN_URL=http://localhost:2019
