# ── Core ──
NEXT_PUBLIC_APP_URL=https://app.getsignalhooks.com
FOLLOWUP_ENGINE_API_TOKEN=change-me-to-a-long-random-string

# ── Database (Turso) ──
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token
TURSO_PROSPECT_DATABASE_URL=libsql://your-prospect-db.turso.io
TURSO_PROSPECT_AUTH_TOKEN=your-prospect-turso-token

# ── AI & Search ──
CLAUDE_API_KEY=sk-ant-...
EXA_API_KEY=exa-...

# ── HubSpot OAuth (create app at developers.hubspot.com) ──
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── Salesforce OAuth (create Connected App in SF Setup) ──
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# ── n8n Container Management ──
N8N_DOCKER_IMAGE=n8nio/n8n:latest
N8N_PORT_START=5680
N8N_PORT_END=5780
N8N_DOCKER_NETWORK=gsh-n8n

# ── Auth.js ──
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://app.getsignalhooks.com

# ── SendGrid ──
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=outreach@getsignalhooks.com
SENDGRID_INBOUND_SECRET=change-me-to-a-long-random-string

# ── Caddy / Domains ──
APP_DOMAIN=app.getsignalhooks.com
N8N_DOMAIN=n8n.getsignalhooks.com
CADDY_ADMIN_URL=http://caddy:2019
