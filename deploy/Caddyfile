{
	# Enable admin API so the app can register n8n routes dynamically
	admin 0.0.0.0:2019
}

# ── Main app ──
{$APP_DOMAIN:app.getsignalhooks.com} {
	reverse_proxy app:3000
}

# ── API docs (same domain, /docs path) ──
# Already handled by Next.js routing via the reverse_proxy above.

# ── Wildcard TLS for n8n subdomains ──
# Individual n8n routes are added dynamically via Caddy's admin API
# when containers are provisioned. Format:
#   {name}.{N8N_DOMAIN} → gsh-n8n-{name}:5678
#
# The app calls POST http://caddy:2019/config/apps/http/servers/n8n/routes
# to register each route. See src/lib/n8n/caddy.ts
